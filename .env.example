# ============================================================
# Financial RAG Engine — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- LLM Backend ---
# Free tier at https://console.groq.com
# Leave blank to use Ollama local fallback (llama3.2:3b)
GROQ_API_KEY=

# --- API Security ---
# Admin key: grants access to POST /api/v1/ingest
ADMIN_API_KEY=change_me_admin_key_123
# Client keys: comma-separated, grant access to query endpoints
CLIENT_API_KEYS=client_key_1,client_key_2

# --- Storage Paths ---
FAISS_INDEX_PATH=data/index/faiss.index
METADATA_PATH=data/index/metadata.pkl

# --- Model Configuration ---
EMBEDDING_MODEL=all-MiniLM-L6-v2
LLM_MODEL=llama3-8b-8192
LLM_TEMPERATURE=0

# --- Retrieval Configuration ---
TOP_K_RETRIEVAL=10
TOP_K_RERANK=5
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=60

# --- Application ---
LOG_LEVEL=INFO
FLASK_ENV=development
CORS_ORIGINS=*
