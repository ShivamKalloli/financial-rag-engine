{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__elements": {},
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.2.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""},
    {"type": "panel", "id": "gauge", "name": "Gauge", "version": ""},
    {"type": "panel", "id": "barchart", "name": "Bar chart", "version": ""}
  ],
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "type": "timeseries",
      "title": "Request Rate (req/sec)",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "expr": "rate(rag_requests_total[1m])",
          "legendFormat": "{{status}} - {{retrieval_mode}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "reqps", "color": {"mode": "palette-classic"}},
        "overrides": []
      },
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list"}}
    },
    {
      "id": 2,
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "type": "timeseries",
      "title": "Latency p50 / p95 / p99",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(rag_latency_seconds_bucket[5m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(rag_latency_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(rag_latency_seconds_bucket[5m]))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "s", "color": {"mode": "palette-classic"}},
        "overrides": []
      },
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list"}}
    },
    {
      "id": 3,
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 8},
      "type": "timeseries",
      "title": "Error Rate",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "expr": "rate(rag_requests_total{status=\"error\"}[1m]) / rate(rag_requests_total[1m])",
          "legendFormat": "Error Rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "percentunit", "color": {"fixedColor": "red", "mode": "fixed"}},
        "overrides": []
      },
      "options": {"tooltip": {"mode": "single"}}
    },
    {
      "id": 4,
      "gridPos": {"h": 6, "w": 8, "x": 8, "y": 8},
      "type": "timeseries",
      "title": "Retrieval Latency p95",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(rag_retrieval_latency_seconds_bucket[5m]))",
          "legendFormat": "Retrieval p95",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "s", "color": {"fixedColor": "blue", "mode": "fixed"}},
        "overrides": []
      },
      "options": {"tooltip": {"mode": "single"}}
    },
    {
      "id": 5,
      "gridPos": {"h": 6, "w": 8, "x": 16, "y": 8},
      "type": "stat",
      "title": "FAISS Index Size",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "expr": "rag_index_size",
          "legendFormat": "Index Size",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 10},
              {"color": "green", "value": 100}
            ]
          }
        },
        "overrides": []
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "background"}
    },
    {
      "id": 6,
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 14},
      "type": "timeseries",
      "title": "Sentiment Distribution",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "expr": "rate(rag_sentiment_total[5m])",
          "legendFormat": "{{label}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "short", "color": {"mode": "palette-classic"}},
        "overrides": []
      },
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list"}}
    },
    {
      "id": 7,
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 14},
      "type": "timeseries",
      "title": "Retrieval Score Distribution",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(rag_retrieval_score_bucket[5m]))",
          "legendFormat": "Similarity p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(rag_retrieval_score_bucket[5m]))",
          "legendFormat": "Similarity p95",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "percentunit", "color": {"mode": "palette-classic"}},
        "overrides": []
      },
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list"}}
    }
  ],
  "refresh": "15s",
  "schemaVersion": 39,
  "tags": ["rag", "financial", "ml"],
  "templating": {"list": []},
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Financial RAG Engine Dashboard",
  "uid": "financial-rag-engine",
  "version": 1
}
